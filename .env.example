# Server-side only — read by api/bls.js. Never prefix this with VITE_, or
# it would be bundled into the public client JS and exposed to visitors.
#
# Get a free key at https://www.bls.gov/developers/, then set it as a
# Vercel Project Settings -> Environment Variable named BLS_API_KEY
# (and/or in a local, gitignored .env for `vercel dev`).
BLS_API_KEY=
